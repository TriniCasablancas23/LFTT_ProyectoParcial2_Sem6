@page
@model Proyec_Tienda_musica.Pages.RecomendacionesModel
@{
    ViewData["Title"] = "Recomendaciones";
}

<div class="page-header">
    <h1>Recomendaciones</h1>
    <p class="subtitle">— ¿Cuál es tu instrumento? —</p>
</div>

<div class="content-wrapper">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="strokes-card">
                <h3>🌱 Principiantes</h3>
                <ul style="line-height:2; padding-left:20px">
                    <li><strong>Ukulele</strong> — Fácil y económico</li>
                    <li><strong>Guitarra acústica</strong> — Ideal para acordes</li>
                    <li><strong>Cajón peruano</strong> — Ritmo sin teoría</li>
                </ul>
            </div>
        </div>
        <div class="col-md-4">
            <div class="strokes-card">
                <h3>🎯 Intermedio</h3>
                <ul style="line-height:2; padding-left:20px">
                    <li><strong>Guitarra eléctrica</strong> — Más géneros</li>
                    <li><strong>Teclado 61 teclas</strong> — Armonía y melodía</li>
                    <li><strong>Bajo eléctrico</strong> — Base de banda</li>
                </ul>
            </div>
        </div>
        <div class="col-md-4">
            <div class="strokes-card">
                <h3>🏆 Avanzado</h3>
                <ul style="line-height:2; padding-left:20px">
                    <li><strong>Batería acústica</strong> — Dedicación total</li>
                    <li><strong>Saxofón</strong> — Alta expresividad</li>
                    <li><strong>Piano digital</strong> — Teoría a fondo</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="strokes-card">
        <h3>💡 Consejo</h3>
        <p>Siempre prueba el instrumento antes de comprarlo. En nuestra tienda puedes tocarlo directamente. ¡Tu comodidad con el instrumento es lo más importante!</p>
    </div>
</div>