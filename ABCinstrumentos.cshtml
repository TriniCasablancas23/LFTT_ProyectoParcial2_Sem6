@page
@using Proyec_Tienda_musica.Modelos
@model Proyec_Tienda_musica.Pages.ABCinstrumentosModel
@{
    ViewData["Title"] = "Instrumentos";
}

<div class="page-header">
    <h1>Instrumentos</h1>
    <p class="subtitle">— Gestión de inventario —</p>
</div>

<div class="content-wrapper">

    @* ── FORMULARIO DE ALTA ──────────────────────────────────────────────────
       asp-page-handler="Agregar" indica que este form llama al método OnPostAgregar()
       del PageModel al ser enviado. *@
    <div class="strokes-card strokes-form">
        <h3>➕ Agregar Instrumento</h3>
        <form method="post" asp-page-handler="Agregar">
            <div class="row g-3">
                @* Cada input usa el prefijo NuevoInstrumento. para que [BindProperty]
                   enlace correctamente el valor con la propiedad del PageModel *@
                <div class="col-md-4">
                    <label>Instrumento</label>
                    <input type="text" name="NuevoInstrumento.Instrumento_Nombre" placeholder="Ej. Guitarra acústica" />
                </div>
                <div class="col-md-4">
                    <label>Marca</label>
                    <input type="text" name="NuevoInstrumento.Marca" placeholder="Ej. Fender" />
                </div>
                <div class="col-md-4">
                    <label>Descripción</label>
                    <input type="text" name="NuevoInstrumento.Descripcion" placeholder="Descripción breve" />
                </div>
                <div class="col-md-4">
                    <label>Precio (MXN)</label>
                    <input type="number" name="NuevoInstrumento.Precio" placeholder="0.00" step="0.01" />
                </div>
                <div class="col-md-4">
                    <label>Existencia</label>
                    <input type="number" name="NuevoInstrumento.Existencia" placeholder="0" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn-strokes w-100">Agregar</button>
                </div>
            </div>
        </form>
    </div>

    <div class="ornament">* * * * *</div>

    @* ── TABLA DE INVENTARIO ─────────────────────────────────────────────────
       Model.Instrumentos contiene la lista cargada por OnGet() desde SQL Server *@
    <h2 class="section-title">📋 Inventario</h2>
    <div style="overflow-x:auto">
        <table class="strokes-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Instrumento</th>
                    <th>Marca</th>
                    <th>Descripción</th>
                    <th>Precio</th>
                    <th>Existencia</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @* Itera sobre cada instrumento recuperado de la base de datos *@
                @foreach (Tienda i in Model.Instrumentos)
                {
                    @* Fila principal con los datos del instrumento *@
                    <tr>
                        <td>@i.Id</td>
                        <td>@i.Instrumento_Nombre</td>
                        <td>@i.Marca</td>
                        <td>@i.Descripcion</td>
                        <td>$@i.Precio</td>
                        <td>@i.Existencia</td>
                        <td>
                            @* Botón que llama a toggleEditar() para mostrar u ocultar
                               la fila de edición correspondiente a este registro *@
                            <button type="button" class="btn-strokes btn-strokes-outline"
                                    onclick="toggleEditar(@i.Id)">
                                Editar
                            </button>
                            @* Formulario de Baja: asp-route-id envía el Id como
                               parámetro a OnPostEliminar(int id) en el PageModel *@
                            <form method="post" asp-page-handler="Eliminar"
                                  asp-route-id="@i.Id" style="display:inline">
                                <button type="submit" class="btn-strokes btn-strokes-danger">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>

                    @* Fila de edición: oculta por defecto, se muestra con toggleEditar().
                       El id del elemento HTML usa el Id del instrumento para ser único. *@
                    <tr id="editar-@i.Id" class="fila-editar" style="display:none">
                        <td colspan="7" style="padding:16px">
                            @* Formulario de Actualización: envía los datos al handler OnPostEditar() *@
                            <form method="post" asp-page-handler="Editar" class="strokes-form">
                                @* Campo oculto que envía el Id del registro a actualizar *@
                                <input type="hidden" name="InstrumentoEditar.Id" value="@i.Id" />
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-2">
                                        <label>Instrumento</label>
                                        <input type="text" name="InstrumentoEditar.Instrumento_Nombre" value="@i.Instrumento_Nombre" />
                                    </div>
                                    <div class="col-md-2">
                                        <label>Marca</label>
                                        <input type="text" name="InstrumentoEditar.Marca" value="@i.Marca" />
                                    </div>
                                    <div class="col-md-2">
                                        <label>Descripción</label>
                                        <input type="text" name="InstrumentoEditar.Descripcion" value="@i.Descripcion" />
                                    </div>
                                    <div class="col-md-2">
                                        <label>Precio</label>
                                        <input type="number" name="InstrumentoEditar.Precio" value="@i.Precio" step="0.01" />
                                    </div>
                                    <div class="col-md-1">
                                        <label>Existencia</label>
                                        <input type="number" name="InstrumentoEditar.Existencia" value="@i.Existencia" />
                                    </div>
                                    <div class="col-md-3 d-flex gap-2 align-items-end">
                                        <button type="submit" class="btn-strokes w-100">Guardar</button>
                                        @* Cancelar vuelve a ocultar la fila sin enviar el formulario *@
                                        <button type="button" class="btn-strokes btn-strokes-danger w-100"
                                                onclick="toggleEditar(@i.Id)">
                                            Cancelar
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Función que muestra u oculta la fila de edición de un instrumento específico.
        // Recibe el Id del instrumento y busca el elemento HTML con id="editar-{id}".
        // Si la fila está oculta (display:none) la muestra, y viceversa.
        function toggleEditar(id) {
            const fila = document.getElementById('editar-' + id);
            fila.style.display = fila.style.display === 'none' ? 'table-row' : 'none';
        }
    </script>
}